#active-section {
    height: auto;
    min-height: 7;
    max-height: 60%;
    &.-empty {
        opacity: 30%;
    }
}

#history-section {
    height: 1fr;
    opacity: 60%;
    border: round $accent 40%;
    &:focus-within {
        opacity: 100%;
        border: round $accent 70%;
    }
}

#active-table {
    height: auto;
}

#history-table {
    height: 1fr;
}

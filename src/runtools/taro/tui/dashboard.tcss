#active-section {
    height: auto;
    min-height: 7;
    max-height: 60%;
    background: $accent 8%;
    border: round $accent 50%;
    &:focus-within {
        border: round $accent;
    }
}

#history-section {
    height: 1fr;
    border: round $primary 40%;
    &:focus-within {
        border: round $primary 70%;
    }
}

#active-table {
    height: auto;
}

#history-table {
    height: 1fr;
}
